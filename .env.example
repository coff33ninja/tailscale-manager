# Tailscale API key — create at https://login.tailscale.com/admin/settings/keys
# Requires read/write access to manage ACLs
TAILSCALE_API_KEY=tskey-api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your tailnet identifier (e.g. "your-tailnet.ts.net" or the tailnet ID)
# Find it at https://login.tailscale.com/admin/settings/general
TAILSCALE_TAILNET=your-tailnet.ts.net
